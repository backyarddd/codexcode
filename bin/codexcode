#!/usr/bin/env bash
# CodexCode entry shim. Resolves this file through symlinks, then executes the
# compiled Node.js CLI from the checkout that owns the real shim.
set -e

SOURCE="${BASH_SOURCE[0]}"
while [ -L "$SOURCE" ]; do
    DIR="$(cd "$(dirname "$SOURCE")" >/dev/null 2>&1 && pwd)"
    TARGET="$(readlink "$SOURCE")"
    case "$TARGET" in
        /*) SOURCE="$TARGET" ;;
        *) SOURCE="$DIR/$TARGET" ;;
    esac
done
SCRIPT_DIR="$(cd "$(dirname "$SOURCE")" >/dev/null 2>&1 && pwd)"
ROOT="$(cd "$SCRIPT_DIR/.." >/dev/null 2>&1 && pwd)"
CLI="$ROOT/dist/src/cli.js"

if ! command -v node >/dev/null 2>&1; then
    cat >&2 <<EOF
CodexCode requires Node.js 20 or newer and could not find node on PATH.

Install Node.js and run codexcode again. Suggested commands:

  macOS (Homebrew):    brew install node
  Debian / Ubuntu:     sudo apt-get update && sudo apt-get install -y nodejs npm
  Fedora / RHEL:       sudo dnf install -y nodejs npm
  Arch Linux:          sudo pacman -S nodejs npm

EOF
    exit 127
fi

if [ ! -f "$CLI" ]; then
    cat >&2 <<EOF
CodexCode is not built yet. Run this from the CodexCode checkout:

  npm install
  npm run build

Or rerun:

  ./install.sh

EOF
    exit 127
fi

exec node "$CLI" "$@"
